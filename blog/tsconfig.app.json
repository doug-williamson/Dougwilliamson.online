/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [
      "node"
    ],
    "paths": {
      "@foliokit/cms-core": ["./node_modules/@foliokit/cms-core/src/index.ts"],
      "@foliokit/cms-ui": ["./node_modules/@foliokit/cms-ui/src/index.ts"],
      "@foliokit/cms-markdown": ["./node_modules/@foliokit/cms-markdown/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "node_modules/@foliokit/*/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "node_modules/@foliokit/*/src/**/*.spec.ts",
    "node_modules/@foliokit/cms-core/src/lib/firebase/firebase-admin.ts"
  ]
}
