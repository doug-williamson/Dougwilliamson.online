rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSiteAdmin() {
      return request.auth != null
        && request.auth.token.email == 'douglasmwilliamson@gmail.com';
    }

    // Public read for all files (blog images, author photos, etc.)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isSiteAdmin();
    }
  }
}
