rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Site config — public read, authenticated admin write
    match /sites/{siteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Posts — published are public, all writes require admin
    match /sites/{siteId}/posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Authors — public read, admin write
    match /sites/{siteId}/authors/{authorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tags — public read, admin write
    match /sites/{siteId}/tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isAdmin() {
      return request.auth != null;
    }
  }
}
